# Copy to .env and fill in. .env is gitignored.
#
# NOTE: do NOT set ANTHROPIC_API_KEY. The Claude Agent SDK inherits OAuth
# credentials from the `claude` CLI (Max subscription billing). Setting an
# explicit API key here would override that and bill API credits instead.

# FRED / ALFRED — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Postgres — match docker-compose.yml (host port 5433 to avoid clashing with a
# system Postgres on 5432 if one is present).
DATABASE_URL=postgresql://aii:aii@localhost:5433/aii
