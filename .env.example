# Copy to .env and fill in. .env is gitignored.

# FRED / ALFRED — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Anthropic — used by the Claude Agent SDK
ANTHROPIC_API_KEY=your_anthropic_key_here

# Postgres connection — match docker-compose.yml for local dev
DATABASE_URL=postgresql://aii:aii@localhost:5432/aii

# Optional: override default config paths (rare)
# AII_CONFIG_DIR=./config
